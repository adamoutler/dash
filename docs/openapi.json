  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "JsonRpcRequest": {
        "properties": {
          "jsonrpc": {
            "type": "string",
            "title": "Jsonrpc"
          },
          "method": {
            "type": "string",
            "title": "Method"
          },
          "params": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Params"
          },
          "id": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Id"
          }
        },
        "type": "object",
        "required": [
          "jsonrpc",
          "method"
        ],
        "title": "JsonRpcRequest"
      },
      "Node": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Unique identifier for the node"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Display name of the node"
          },
          "type": {
            "$ref": "#/components/schemas/NodeType",
            "description": "Type of the node in the hierarchy"
          },
          "path": {
            "type": "string",
            "title": "Path",
            "description": "Hierarchical path to this node"
          },
          "has_children": {
            "type": "boolean",
            "title": "Has Children",
            "description": "Whether this node can be expanded further",
            "default": false
          },
          "url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Url",
            "description": "External URL to view this node"
          },
          "metadata": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Metadata",
            "description": "Provider-specific metadata"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "type",
          "path"
        ],
        "title": "Node"
      },
      "NodeList": {
        "properties": {
          "provider": {
            "$ref": "#/components/schemas/ProviderType",
            "description": "The git provider"
          },
          "path": {
            "type": "string",
            "title": "Path",
            "description": "The path that was explored"
          },
          "nodes": {
            "items": {
              "$ref": "#/components/schemas/Node"
            },
            "type": "array",
            "title": "Nodes",
            "description": "List of child nodes under the given path"
          }
        },
        "type": "object",
        "required": [
          "provider",
          "path",
          "nodes"
        ],
        "title": "NodeList"
      },
      "NodeType": {
        "type": "string",
        "enum": [
          "PROVIDER_ROOT",
          "ORGANIZATION",
          "USER",
          "REPOSITORY",
          "FOLDER",
          "WORKFLOW",
          "JOB"
        ],
        "title": "NodeType"
      },
      "ProviderType": {
        "type": "string",
        "enum": [
          "github",
          "forgejo",
          "gitea",
          "jenkins"
        ],
        "title": "ProviderType"
      },
      "RepoItem": {
        "properties": {
          "provider": {
            "$ref": "#/components/schemas/ProviderType",
            "description": "The git provider"
          },
          "owner": {
            "type": "string",
            "title": "Owner",
            "description": "The repository owner or organization name"
          },
          "repo": {
            "type": "string",
            "title": "Repo",
            "description": "The repository name"
          },
          "branch": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Branch",
            "description": "The specific branch to track. If omitted, uses the default branch."
          },
          "custom_links": {
