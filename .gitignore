# Ignore everything in the root
/*

# Whitelist allowed root directories and files
!/.gemini/
!/.github/
!/cli/
!/docs/
!/src/
!/tests/
!/.dockerignore
!/.gitignore
!/.npmignore
!/.pre-commit-config.yaml
!/.spectral.yaml
!/docker-compose.yml
!/Dockerfile
!/GEMINI.md
!/Jenkinsfile
!/LICENSE
!/package-lock.json
!/package.json
!/promptfooconfig.yaml
!/pytest.ini
!/README.md
!/requirements.txt
!/safeskill-registration.md
!/safeskill.manifest.json
!/SECURITY.md
!/test_version.py
!/VERSION

# The original rules for subdirectories
.worktrees/
~/
node_modules/

# Environments
.venv/
env/
venv/
env.bak/
venv.bak/

# Caches and Temp Files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.coverage
.coveragerc
.superpowers/
logs/
data/
*.log

# Sensitive Files
.gemini/settings.json

# Plans
plans/
